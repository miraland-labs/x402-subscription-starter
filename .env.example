# ── Service identity ─────────────────────────────────────────────────────────
SERVICE_NAME=x402-subscription-starter
SERVICE_DISPLAY_NAME=My Subscription API
PORT=3000
SELLER_PUBLIC_BASE_URL=http://127.0.0.1:3000

# ── pr402 (same contract as x402-seller-starter) ─────────────────────────────
FACILITATOR_BASE_URL=https://preview.ipay.sh
MERCHANT_WALLET=<your_base58_merchant_pubkey>

# Fallback x402 vars when parameters table has no row for a tier endpoint.
# Per-tier pricing SHOULD live in SQLite — run scripts/parameters-seed-devnet.sql
X402_SCHEME=exact
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
X402_ASSET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
X402_AMOUNT=50000
X402_PAY_TO=<vault_pda_from_find_payto>
X402_MAX_TIMEOUT_SECONDS=120
X402_ACCEPTS_EXTRA_JSON={"merchantWallet":"<your_base58_merchant_pubkey>"}

# ── Subscription (Tier A — local JWT) ───────────────────────────────────────
JWT_SECRET=<openssl rand -hex 32>
DATABASE_URL=./data/subscription.db

# Tier B (hosted auth): set SUBSCRIPTION_MODE=tier-b + subscription-auth vars —
# see examples/tier-b-preview-e2e/.env.example and subscription-auth/docs/SUBSCRIPTION_AUTH_FOR_SELLERS.md

# ── Rate limits ──────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_PER_MIN=200
RATE_LIMIT_PER_PAYER_PER_MIN=60
TRUST_PROXY=1
