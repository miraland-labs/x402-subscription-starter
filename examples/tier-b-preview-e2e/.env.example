# Tier B preview E2E — seller env (copy to .env.local, never commit)
# Path B only — default starter quick start uses JWT_SECRET (Tier A).

SUBSCRIPTION_MODE=tier-b
SUBSCRIPTION_AUTH_BASE_URL=https://preview.auth.ipay.sh
SUBSCRIPTION_AUTH_ISS=https://preview.auth.ipay.sh
SUBSCRIPTION_AUTH_SERVICE_ID=e2e.local.ipay.sh
# Base58 of full 64-byte Solana secret key (see README export one-liner)
SUBSCRIPTION_AUTH_MERCHANT_SECRET_KEY=<your_seller_secret_key_base58>

PORT=3000
SELLER_PUBLIC_BASE_URL=http://127.0.0.1:3000
SERVICE_NAME=x402-subscription-starter
SERVICE_DISPLAY_NAME="Tier B Preview E2E Seller"

FACILITATOR_BASE_URL=https://preview.ipay.sh
MERCHANT_WALLET=SELdziqdQuyUWsaKkvdV1oMLUtK1Hrj8XPgtdPEy58W

# Devnet exact rail (payTo = merchant wallet — same as pr402 devnet e2e)
X402_SCHEME=exact
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
X402_ASSET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
X402_AMOUNT=50000
X402_PAY_TO=SELdziqdQuyUWsaKkvdV1oMLUtK1Hrj8XPgtdPEy58W
X402_MAX_TIMEOUT_SECONDS=120
X402_ACCEPTS_EXTRA_JSON={"merchantWallet":"SELdziqdQuyUWsaKkvdV1oMLUtK1Hrj8XPgtdPEy58W"}

DATABASE_URL=./data/subscription-tier-b-e2e.db
REVOCATION_POLL_INTERVAL_SEC=60
